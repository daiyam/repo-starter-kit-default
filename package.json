{
	"name": "@daiyam/repo-starter-kit-default",
	"description": "Opinionated repo starter kit: default configs, issue labels, and templates",
	"version": "0.4.1",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/daiyam/repo-starter-kit-default",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/daiyam/repo-starter-kit-default.git"
	},
	"bugs": {
		"url": "https://github.com/daiyam/repo-starter-kit-default/issues"
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"lint:all": "npm run lint:package && npm audit && npm run ci:lint",
		"lint:package": "fixpack || true",
		"prepare": "husky; npm run lint:package",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run --update",
		"update:deps": "taze --all"
	},
	"dependencies": {},
	"devDependencies": {
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.2.0",
		"taze": "19.14.1"
	},
	"overrides": {
		"@inquirer/core": {
			"mute-stream": "3.0.0"
		},
		"release-it": {
			"undici": "7.28.0"
		}
	},
	"keywords": []
}
